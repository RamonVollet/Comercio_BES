# ===========================================
# Comercio BES - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# --- Banco de Dados ---
# SQLite (desenvolvimento local - padrao):
DATABASE_URL="file:./dev.db"

# PostgreSQL (producao - Supabase ou Hostinger):
# DATABASE_URL="postgresql://USER:SENHA@HOST:5432/comercio_bes?schema=public"

# MySQL (Hostinger):
# DATABASE_URL="mysql://USER:SENHA@HOST:3306/comercio_bes"

# --- JWT ---
JWT_SECRET="trocar-por-uma-chave-secreta-longa-e-aleatoria"
# JWT_EXPIRES_IN foi substituído: access_token=15min, refresh_token=7d (gerenciado no authController)

# --- Painéis Legados (/admin e /painel) ---
# on  → manter legados funcionais (padrão durante migração)
# off → redirecionar legados para /minha-conta com 301
LEGACY_PANELS="on"

# --- Servidor ---
PORT=3000
NODE_ENV="development"

# --- Cloudinary (upload de imagens) ---
# Crie uma conta gratuita em https://cloudinary.com
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# --- Frontend URL (CORS) ---
FRONTEND_URL="http://localhost:5500"

# --- Pagamentos (Mercado Pago) ---
# Sandbox: use credenciais de teste do Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="seu-access-token"
MERCADO_PAGO_PUBLIC_KEY="sua-public-key"

# URL publica do backend para webhook de pagamento
# Exemplo: https://api.seudominio.com
WEBHOOK_BASE_URL="http://localhost:3000"
