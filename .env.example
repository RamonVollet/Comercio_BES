# Comercio BES - variaveis de ambiente
# Copie para .env e troque senhas/chaves antes de expor a API.

# Dominio
API_DOMAIN=api.comerciobes.com.br
FRONTEND_URL=https://comerciobes.com.br
WEBHOOK_BASE_URL=https://api.comerciobes.com.br
COOKIE_DOMAIN=.comerciobes.com.br

# Banco Docker local/producao
POSTGRES_USER=comerciobes
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=comerciobes
POSTGRES_TEST_DB=comerciobes_test

# Comandos rodando no Windows usam 127.0.0.1. A API no Docker troca para o host interno "postgres" pelo docker-compose.yml.
DATABASE_URL=postgresql://comerciobes:troque-esta-senha@127.0.0.1:5432/comerciobes?schema=public
DIRECT_URL=postgresql://comerciobes:troque-esta-senha@127.0.0.1:5432/comerciobes?schema=public

# Testes rodando no host usam o Postgres de teste exposto em 127.0.0.1:5433.
TEST_DATABASE_URL=postgresql://comerciobes:troque-esta-senha@127.0.0.1:5433/comerciobes_test?schema=public

# Timeouts opcionais para falhas de conectividade retornarem rapido.
DB_CONNECT_TIMEOUT_SECONDS=10
DB_POOL_TIMEOUT_SECONDS=10
DB_HEALTH_TIMEOUT_MS=5000

# Servidor
NODE_ENV=production
PORT=3000

# Homologacao privada
# Defina SITE_PASSWORD em producao/homologacao para exigir usuario/senha no navegador.
SITE_USERNAME=comerciobes
SITE_PASSWORD=

# Auth
# Gere uma chave longa e aleatoria. Exemplo: openssl rand -base64 64
JWT_SECRET=trocar-por-uma-chave-secreta-longa-e-aleatoria

# Upload de imagens opcional
# Se ausente, o sistema usa backend/uploads local.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pagamentos Mercado Pago - opcional
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# Nao habilite em publico; serve apenas para homologacao sem banco.
AUTH_FALLBACK_ENABLED=false
